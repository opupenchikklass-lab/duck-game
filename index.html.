<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Duck Clicker</title>
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <style>
        body { 
            background: radial-gradient(circle, #ffeb3b, #fbc02d); 
            display: flex; 
            flex-direction: column; 
            align-items: center; 
            justify-content: center; 
            height: 100vh; 
            margin: 0; 
            font-family: 'Arial', sans-serif; 
            overflow: hidden; 
            user-select: none;
        }
        #score { 
            font-size: 60px; 
            font-weight: bold; 
            color: #3e2723; 
            margin-bottom: 10px; 
        }
        #duck-container {
            position: relative;
            display: flex;
            justify-content: center;
            align-items: center;
        }
        #duck { 
            width: 220px; 
            cursor: pointer; 
            transition: transform 0.05s; 
            -webkit-tap-highlight-color: transparent;
        }
        #duck:active { 
            transform: scale(0.85); 
        }
        .tap-text {
            position: absolute;
            color: #3e2723;
            font-weight: bold;
            font-size: 24px;
            pointer-events: none;
            animation: floatUp 0.5s ease-out forwards;
        }
        @keyframes floatUp {
            0% { opacity: 1; transform: translateY(0); }
            100% { opacity: 0; transform: translateY(-100px); }
        }
    </style>
</head>
<body>
    <div id="score">0</div>
    <div id="duck-container">
        <img id="duck" src="https://img.icons8.com/emoji/256/duck-emoji.png" alt="Duck">
    </div>

    <script>
        const tg = window.Telegram.WebApp;
        tg.expand();
        tg.headerColor = '#ffeb3b';

        let score = 0;
        const duck = document.getElementById('duck');
        const scoreDisplay = document.getElementById('score');
        const container = document.getElementById('duck-container');

        duck.addEventListener('touchstart', (e) => {
            e.preventDefault(); // Чтобы не было лишних зумов
            score++;
            scoreDisplay.innerText = score;

            // Вибрация
            if (tg.HapticFeedback) {
                tg.HapticFeedback.impactOccurred('medium');
            }

            // Вылетающий текст +1
            const text = document.createElement('div');
            text.innerText = '+1';
            text.className = 'tap-text';
            text.style.left = (e.touches[0].clientX - 20) + 'px';
            text.style.top = '-50px';
            container.appendChild(text);
            
            setTimeout(() => text.remove(), 500);
        });
    </script>
</body>
</html>
